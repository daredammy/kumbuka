# Kumbuka Configuration Example
# Copy this file to ~/.kumbuka/kumbuka.env and adjust the values.

# -----------------------------------------------------------------------------
# Notes Destination (Optional)
# -----------------------------------------------------------------------------
# terminal  = don't save notes anywhere, just print them
# notion    = save to Notion
# obsidian  = write markdown into an Obsidian vault
# If unset, Kumbuka auto-detects: notion first, then obsidian, else terminal.
KUMBUKA_NOTES_DESTINATION=""

# -----------------------------------------------------------------------------
# Obsidian (Optional)
# -----------------------------------------------------------------------------
# Path to your Obsidian vault directory.
# Example: ~/Documents/Obsidian
KUMBUKA_OBSIDIAN_VAULT=""

# Optional folder inside the vault for meeting notes.
# Example: Meetings
KUMBUKA_OBSIDIAN_FOLDER=""

# -----------------------------------------------------------------------------
# Notion (Optional)
# -----------------------------------------------------------------------------
# "token" = API token (requires NOTION_TOKEN below)
# "mcp"   = Claude MCP integration (requires Notion MCP connected in Claude Code)
KUMBUKA_NOTION_MODE="token"

# URL of the Notion page where meeting notes should be created as subpages.
# Example: https://www.notion.so/My-Meetings-abc123...
KUMBUKA_NOTION_URL=""

# Notion Integration Token (required when notion_mode is "token")
# Create one at https://www.notion.so/profile/integrations
# Starts with "ntn_"
NOTION_TOKEN=""

# -----------------------------------------------------------------------------
# FluidAudio Configuration
# -----------------------------------------------------------------------------
# Path to the FluidAudio repository.
# Clone from: https://github.com/FluidInference/FluidAudio
KUMBUKA_FLUIDAUDIO_REPO="~/FluidAudio"

# -----------------------------------------------------------------------------
# Output Directory
# -----------------------------------------------------------------------------
# Where recordings, transcripts, and logs are saved.
# Default: ~/.kumbuka/recordings
# KUMBUKA_OUTPUT_DIR="/path/to/your/directory"

# -----------------------------------------------------------------------------
# Recording & Monitoring
# -----------------------------------------------------------------------------
# Maximum recording duration in seconds.
# 7200 = 2 hours
# 14400 = 4 hours
KUMBUKA_MAX_RECORDING_SECONDS="14400"

# How many minutes before a meeting starts to detect it.
KUMBUKA_PROMPT_MINUTES="2"

# Auto-record mode: "true" records automatically, "false" shows a dialog prompt.
KUMBUKA_AUTO_RECORD="true"

# Minutes to keep recording after the meeting's scheduled end time.
KUMBUKA_BUFFER_MINUTES="10"

# -----------------------------------------------------------------------------
# Personalization
# -----------------------------------------------------------------------------
# Your name (used for transcript attribution and personalized feedback)
KUMBUKA_USER_NAME="Me"
